rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // HELPERS
    // ─────────────────────────────────────────────────────────────

    // isAdmin: check by UID (legacy) OR by email (new convention).
    // Keying admins by email means any OAuth provider (Google, Microsoft,
    // email/password) works without UID-lookup failures.
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email != null &&
         exists(/databases/$(database)/documents/admins/$(request.auth.token.email)))
      );
    }

    // hasRole: check users/{uid} for an active profile with the given role.
    // After an OAuth email-fallback login, users/{uid} is created automatically
    // so this always works after the first sign-in.
    function hasRole(role) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // isActiveUser: any authenticated user with an active users/{uid} document.
    function isActiveUser() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    // ─────────────────────────────────────────────────────────────
    // users collection
    //   get:    own UID or admin
    //   list:   any authenticated user (needed for email-fallback query)
    //   create: own UID (auto-link after OAuth sign-in)
    //   update/delete: admin only
    // ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow get:    if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // admins collection  (docId is either a UID or an email)
    //   read:   own document (by UID or email) or any admin
    //   list:   any authenticated user (for email-fallback query)
    //   create: (a) admin write privilege, OR
    //           (b) self-service email-keyed doc if users/{uid} says role='admin'
    //               — this covers the OAuth migration path without backend help
    //   update/delete: admin only
    // ─────────────────────────────────────────────────────────────
    match /admins/{docId} {
      allow read: if request.auth != null && (
        request.auth.uid      == docId ||
        request.auth.token.email == docId ||
        isAdmin()
      );
      allow list: if request.auth != null;
      // Self-service creation of email-keyed admin doc when the users/{uid}
      // profile already says role='admin' (set by an existing admin via users.html)
      allow create: if request.auth != null &&
        docId == request.auth.token.email &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // reports collection
    //   Admins:      full read/write
    //   Power users: full read/write (create and manage surveys)
    //   Clients:     read-only for reports where clientEmail matches
    // ─────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read, write: if isAdmin();
      allow read, write: if hasRole('power_user');
      allow read: if isActiveUser() &&
        !resource.data.get('deleted', false) &&
        resource.data.clientEmail == request.auth.token.email;
    }

    // ─────────────────────────────────────────────────────────────
    // clients collection  (legacy — keyed by email)
    // ─────────────────────────────────────────────────────────────
    match /clients/{docId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null &&
        request.auth.token.email == docId;
    }

  }
}
